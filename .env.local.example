# ── LLM (Groq, server-side only) ─────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# ── Puter.js TTS (free, no key) ──────────────────────────────────────────────
# Loaded via <Script src="https://js.puter.com/v2/"> in src/app/layout.tsx.
# Browser STT uses webkitSpeechRecognition — also no key required.
